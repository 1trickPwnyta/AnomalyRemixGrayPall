<?xml version="1.0" encoding="utf-8" ?>

<Defs>

  <WorldObjectDef ParentName="StaticWorldObjectBase">
    <defName>GrayPallMonolithB</defName>
    <label>sinister location</label>
    <description>After studying the monolith, your colonists have an eerie feeling about this place.</description>
    <worldObjectClass>AnomalyRemixGrayPall.WorldObject_MonolithB</worldObjectClass>
    <texture>World/WorldObjects/Sites/GenericSite</texture>
    <expandingIcon>true</expandingIcon>
    <expandingIconTexture>World/WorldObjects/Expanding/SinisterLocation</expandingIconTexture>
    <expandingIconPriority>50</expandingIconPriority>
    <expandMore>true</expandMore>
    <IncidentTargetTags>
      <li>Map_PlayerHome</li>
    </IncidentTargetTags>
    <canBePlayerHome>true</canBePlayerHome>
    <comps>
      <li Class="WorldObjectCompProperties_FormCaravan" />
      <li Class="AnomalyRemixGrayPall.WorldObjectCompProperties_GrayPallQuestSite" />
    </comps>
  </WorldObjectDef>
  
  <WorldObjectDef ParentName="StaticWorldObjectBase">
    <defName>GrayPallSource</defName>
    <label>gray pall source</label>
    <description>After studying the monolith, your colonists have discovered the source of the gray pall. Investigate this place to put an end to it.</description>
    <worldObjectClass>AnomalyRemixGrayPall.WorldObject_GrayPallSource</worldObjectClass>
    <texture>World/WorldObjects/Sites/GenericSite</texture>
    <expandingIcon>true</expandingIcon>
    <expandingIconTexture>World/WorldObjects/Expanding/GrayPallSource</expandingIconTexture>
    <expandingIconPriority>50</expandingIconPriority>
    <expandMore>true</expandMore>
    <IncidentTargetTags>
      <li>Map_PlayerHome</li>
    </IncidentTargetTags>
	<mapGenerator>GrayPallSource</mapGenerator>
    <canBePlayerHome>true</canBePlayerHome>
    <comps>
      <li Class="WorldObjectCompProperties_FormCaravan" />
      <li Class="AnomalyRemixGrayPall.WorldObjectCompProperties_GrayPallQuestSite" />
    </comps>
  </WorldObjectDef>

</Defs>