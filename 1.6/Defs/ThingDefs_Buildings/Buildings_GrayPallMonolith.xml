<?xml version="1.0" encoding="utf-8" ?>

<Defs>
  
  <ThingDef Abstract="true" Name="GrayPallMonolithBase" ParentName="BuildingBase">
    <description>A monolith of unknown age, purpose, and construction. Its smooth surface is etched with lines that twist and writhe in unsettling patterns.</description>
    <passability>Impassable</passability>
    <fillPercent>1</fillPercent>
    <blockWind>true</blockWind>
    <altitudeLayer>Building</altitudeLayer>
    <tickerType>Rare</tickerType>
    <pathCost>50</pathCost>
    <forceDebugSpawnable>true</forceDebugSpawnable>
    <canOverlapZones>false</canOverlapZones>
    <selectable>true</selectable>
    <destroyable>false</destroyable>
    <useHitPoints>false</useHitPoints>
    <preventSkyfallersLandingOn>true</preventSkyfallersLandingOn>
    <uiIconScale>0.75</uiIconScale>
    <terrainAffordanceNeeded>Heavy</terrainAffordanceNeeded>
    <bringAlongOnGravship>false</bringAlongOnGravship>
    <statBases>
      <Flammability>0</Flammability>
      <MeditationFocusStrength>0.3</MeditationFocusStrength>
    </statBases>
	<building>
      <deconstructible>false</deconstructible>
      <repairable>false</repairable>
      <isTargetable>false</isTargetable>
      <isInert>true</isInert>
      <claimable>false</claimable>
      <expandHomeArea>false</expandHomeArea>
    </building>
	<comps>
	  <li Class="CompProperties_MeditationFocus">
        <statDef>MeditationFocusStrength</statDef>
        <focusTypes>
          <li>Void</li>
        </focusTypes>
      </li>
	  <li Class="CompProperties_Glower">
        <glowRadius>12</glowRadius>
        <glowColor>(255,120,120,0)</glowColor>
      </li>
	</comps>
	<inspectorTabs>
      <li>ITab_StudyNotesVoidMonolith</li>
    </inspectorTabs>
  </ThingDef>
  
  <ThingDef ParentName="GrayPallMonolithBase">
    <defName>GrayPallMonolithA</defName>
    <label>dark monolith</label>
    <thingClass>AnomalyRemixGrayPall.Building_GrayPallMonolithA</thingClass>
    <graphicData>
      <graphicClass>Graphic_Single</graphicClass>
      <texPath>Things/Building/VoidMonolith/Core/VoidMonolith_A</texPath>
      <drawSize>(5, 5)</drawSize>
      <shadowData>
        <volume>(2.37, 1, 2.37)</volume>
      </shadowData>
    </graphicData>
    <size>(3, 3)</size>
    <comps>
      <li Class="AnomalyRemixGrayPall.CompProperties_MonolithStudyProgress">
	    <studyRequired>3</studyRequired>
        <studyNotes>
          <li>
            <threshold>1</threshold>
            <label>Monolith study progress</label>
            <text>{PAWN_nameDef} has had a breakthrough while studying the monolith. {PAWN_pronoun} believes the monolith is a conduit for psychic energy, connected somehow to the gray pall.\n\n{PAWN_nameDef} is convinced that by studying the monolith further, {PAWN_pronoun} can find a way to stop the gray pall for good.</text>
          </li>
          <li>
            <threshold>2</threshold>
            <label>Monolith study progress</label>
            <text>{PAWN_nameDef} made progress studying the monolith. {PAWN_pronoun} has discovered that there is a distant location that hides the secret to the source of the gray pall.</text>
          </li>
        </studyNotes>
      </li>
    </comps>
  </ThingDef>
  
  <ThingDef ParentName="GrayPallMonolithBase">
    <defName>GrayPallMonolithB</defName>
    <label>corrupt monolith</label>
    <thingClass>AnomalyRemixGrayPall.Building_GrayPallMonolithB</thingClass>
    <graphicData>
      <graphicClass>Graphic_Single</graphicClass>
      <texPath>Things/Building/GrayPallMonolith/Monolith_B</texPath>
      <drawSize>(5, 3)</drawSize>
      <shadowData>
        <volume>(2.37, 1, 2.37)</volume>
      </shadowData>
    </graphicData>
    <size>(5, 3)</size>
    <comps>
      <li Class="AnomalyRemixGrayPall.CompProperties_MonolithStudyProgress">
	    <studyRequired>3</studyRequired>
        <studyNotes>
          <li>
            <threshold>1</threshold>
            <label>Monolith study progress</label>
            <text>{PAWN_nameDef} has had a breakthrough while studying the monolith. {PAWN_pronoun} has discovered that the gray pall emanates from a twisted realm deep beneath the ground in a distant land.</text>
          </li>
          <li>
            <threshold>2</threshold>
            <label>Monolith study progress</label>
            <text>{PAWN_nameDef} made progress studying the monolith. {PAWN_pronoun} believes the monolith is the final piece of the gray pall puzzle. Solve the mystery of this monolith and you'll discover the source of the gray pall.</text>
          </li>
        </studyNotes>
      </li>
    </comps>
  </ThingDef>

</Defs>